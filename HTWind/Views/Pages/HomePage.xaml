<UserControl
    x:Class="HTWind.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:HTWind.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,8,28,28">
            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Text="{loc:Loc MainWindow_HeaderTitle}"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{loc:Loc MainWindow_HeaderDescription}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:Button
                            Grid.Column="0"
                            Height="36"
                            Content="{loc:Loc MainWindow_AddWidget}"
                            Icon="{ui:SymbolIcon Add24}"
                            Appearance="Primary"
                            Command="{Binding AddWidgetCommand}" />

                        <ui:Button
                            x:Name="AddWidgetOptionsButton"
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            Width="36"
                            Height="36"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon ChevronDown24}"
                            ToolTip="{loc:Loc MainWindow_AddWidgetOptions}"
                            AutomationProperties.Name="{loc:Loc MainWindow_AddWidgetOptions}"
                            Click="AddWidgetOptionsButton_Click">
                            <ui:Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem
                                        Header="{loc:Loc MainWindow_CreateWithEditor}"
                                        Click="CreateWithEditorMenuItem_Click" />
                                </ContextMenu>
                            </ui:Button.ContextMenu>
                        </ui:Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Widgets Section -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="{loc:Loc MainWindow_WidgetsSection}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- Tip Card -->
            <ui:Card Margin="0,0,0,8" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                        Symbol="Info24"
                        FontSize="16"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Grid.Column="1"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{loc:Loc MainWindow_Tips}"
                        TextWrapping="Wrap" />

                    <ui:Button
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Content="{loc:Loc MainWindow_FindMore}"
                        Icon="{ui:SymbolIcon Open24}"
                        ToolTip="{loc:Loc MainWindow_FindMore}"
                        AutomationProperties.Name="{loc:Loc MainWindow_FindMore}"
                        Click="FindMore_Click" />
                </Grid>
            </ui:Card>

            <!-- Widget List -->
            <ItemsControl Name="WidgetsList" ItemsSource="{Binding Widgets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="16,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,6" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{Binding DisplayName}"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Margin="0,0,0,0"
                                        Text="{Binding Name}"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <ui:Button
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Width="34"
                                    Height="34"
                                    VerticalAlignment="Top"
                                    Icon="{ui:SymbolIcon MoreVertical24}"
                                    ToolTip="{loc:Loc MainWindow_WidgetActions}"
                                    AutomationProperties.Name="{loc:Loc MainWindow_WidgetActions}"
                                    Click="WidgetActionsButton_Click">
                                    <ui:Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Header="{loc:Loc MainWindow_ResetPosition}"
                                                Command="{Binding DataContext.ResetWidgetPositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                            <MenuItem
                                                Header="{loc:Loc MainWindow_Edit}"
                                                Command="{Binding DataContext.EditWidgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem
                                                Header="{loc:Loc MainWindow_Remove}"
                                                Command="{Binding DataContext.RemoveWidgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </ui:Button.ContextMenu>
                                </ui:Button>

                                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                                    <ui:ToggleSwitch
                                        Margin="0,2,10,0"
                                        VerticalAlignment="Center"
                                        Content="{loc:Loc MainWindow_Visible}"
                                        IsChecked="{Binding IsVisible}"
                                        Command="{Binding DataContext.ChangeVisibilityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />

                                    <ui:ToggleSwitch
                                        Margin="0,2,10,0"
                                        VerticalAlignment="Center"
                                        Content="{loc:Loc MainWindow_Locked}"
                                        IsChecked="{Binding IsLocked}" />

                                    <ui:ToggleSwitch
                                        Margin="0,2,0,0"
                                        VerticalAlignment="Center"
                                        Content="{loc:Loc MainWindow_PinOnTop}"
                                        IsChecked="{Binding IsPinned}"
                                        Command="{Binding DataContext.ChangePinStateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                </WrapPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <ui:Card HorizontalAlignment="Center" Padding="32,24" Margin="0,20,0,0">
                <ui:Card.Style>
                    <Style TargetType="ui:Card">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Widgets.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Card.Style>
                <StackPanel>
                    <ui:SymbolIcon
                        Symbol="Info24"
                        FontSize="36"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="{loc:Loc MainWindow_EmptyTitle}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{loc:Loc MainWindow_EmptyDescription}" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
